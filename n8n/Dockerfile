FROM n8nio/n8n:2.8.3

# Timezone
ENV GENERIC_TIMEZONE=America/Bogota

# n8n Core
ENV N8N_PORT=5678
ENV N8N_PROTOCOL=https
ENV N8N_PUSH_BACKEND=websocket
ENV N8N_SECURE_COOKIE=false
ENV N8N_ENDPOINT_HEALTH=health
ENV N8N_METRICS=false

# Execution data (reduce storage usage)
ENV EXECUTIONS_DATA_SAVE_ON_ERROR=none
ENV EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
ENV EXECUTIONS_DATA_SAVE_MANUAL_EXECUTION=false

# Database (PostgreSQL) — injected at deploy time
ENV DB_TYPE=postgresdb
ENV DB_POSTGRESDB_PORT=5432
ENV DB_POSTGRESDB_DATABASE=postgres
ENV DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false
ENV DB_POSTGRESDB_CONNECTION_TIMEOUT_MS=30000

EXPOSE 5678
