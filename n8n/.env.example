# n8n Cloud Run — Required environment variables
# Copy this file to .env and fill in the values
# These are injected at deploy time, NOT baked into the Docker image

# ═══════════════════════════════════════════
# PostgreSQL (Supabase)
# ═══════════════════════════════════════════
DB_POSTGRESDB_HOST=db.your-project.supabase.co
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=your-database-password

# ═══════════════════════════════════════════
# n8n Security
# ═══════════════════════════════════════════
N8N_ENCRYPTION_KEY=generate-a-strong-random-key

# ═══════════════════════════════════════════
# Cloud Run URLs (auto-generated by GCP)
# ═══════════════════════════════════════════
WEBHOOK_URL=https://your-service-url.run.app
N8N_EDITOR_BASE_URL=https://your-service-url.run.app
