    {
      "parameters": {
        "jsCode": "const userData = $(\"Find Stalled Users DB\").item.json;\n\nconst lang = userData?.profiles?.language || 'en';\nconst firstName = userData?.profiles?.first_name || 'Usuario';\nconst phone = userData?.profiles?.phone_number || '';\n\nconst promptTemplates = $node[\"Get Safety Prompt\"].json;\nlet selectedPrompt = promptTemplates[lang] || promptTemplates['en'] || \"\";\n\nconst finalPrompt = selectedPrompt\n  .replace(/{{ name }}/g, firstName)\n  .replace(/{{ stall_context }}/g, userData?.raw_content || \"\")\n  .replace(/{{ strategic_insight }}/g, userData?.strategic_insight || \"\")\n  .replace(/{{ title }}/g, userData?.summary_title || \"\");\n\nreturn [{\n  json: {\n    final_prompt: finalPrompt,\n    selected_language: lang,\n    phone_number: phone,\n    first_name: firstName\n  }\n}];"
      },
