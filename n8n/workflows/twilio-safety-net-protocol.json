    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst seenPhones = new Set();\nconst uniqueRescues = [];\n\nfor (const item of items) {\n  // Check for phone_number inside the profiles object\n  const phone = item.json.profiles?.phone_number;\n  \n  if (phone && !seenPhones.has(phone)) {\n    seenPhones.add(phone);\n    // Ensure the structure remains intact for the next nodes\n    uniqueRescues.push(item);\n  }\n}\n\nreturn uniqueRescues;"
      },
