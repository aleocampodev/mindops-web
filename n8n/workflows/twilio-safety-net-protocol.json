              "name": "Twiml",
              "value": "={{ \n  (() => {\n    const lang = $('Process Safety Prompt').item.json.selected_language || 'en';\n    const voice = lang === 'es' ? 'Polly.Lucia-Neural' : 'Polly.Mia-Neural';\n    const twilioLang = lang === 'es' ? 'es-MX' : 'en-US';\n    const script = $('Write Empathic Script (LLM)').item.json.text;\n    return `<Response><Say voice=\"${voice}\" language=\"${twilioLang}\">${script}</Say></Response>`;\n  })()\n}}"
            }
