        "jsCode": "\nconst context = $('Strict Entry (Brain)').item.json.context;\n\n\nconst lang = context.language || 'es';\n\n\nconst promptData = context.prompts.prompt_ai || {};\nconst fullPrompt = promptData[lang] || \"\";\n\nreturn [{\n  json: {\n    final_prompt: fullPrompt,\n    debug_language: lang\n  }\n}];\n"
