      {
        "parameters": {
          "jsCode": "const items = $input.all();\n\nconst memories = items\n  .map(item => item.json.content || item.json.raw_content)\n  .filter(c => c && c.trim() !== \"\")\n  .join(' | ');\n\nconst currentThought = $('Merge Streams').item.json.final_thought;\nconst currentVector = $('Generate Embeddings').item.json.embedding.values;\n\nlet fullPrompt = $('Select Localized Prompt').item.json.final_prompt || \"\";\n\n\nconst historical = memories || \"No previous history.\";\nfullPrompt = fullPrompt.replace('{{historical_context}}', historical);\nfullPrompt = fullPrompt.replace('{{user_thought}}', currentThought);\n\nreturn [{\n  json: {\n    final_thought: currentThought,\n    historical_context: historical,\n    embedding_vector: currentVector,\n    final_prompt: fullPrompt\n  }\n}];\n"
        },
